{
  "rules": [
    {"id": "dl-curl-pipe-sh", "category": "download-exec", "pattern": "(?i)curl(?:\\s+https?://[^|\\s]+)?\\s*\\|\\s*(?:sh|bash|zsh|pwsh|ash|dash)", "severity": 95},
    {"id": "dl-wget-pipe-sh", "category": "download-exec", "pattern": "(?i)wget(?:\\s+https?://[^|\\s]+)?\\s*-O\\s*[^|\\s]+\\s*\\|\\s*(?:sh|bash|zsh|ash|dash)", "severity": 95},
    {"id": "dl-irm-iex", "category": "download-exec", "pattern": "(?i)irm\\s+https?://[^|\\s]+\\s*\\|\\s*iex", "severity": 95},
    {"id": "dl-iwr-iex", "category": "download-exec", "pattern": "(?i)iwr\\s+https?://[^|\\s]+\\s*\\|\\s*iex", "severity": 95},
    {"id": "dl-invoke-webrequest", "category": "download-exec", "pattern": "(?i)Invoke-WebRequest[^|]*\\|\\s*Invoke-Expression", "severity": 95},
    {"id": "dl-webclient-download", "category": "download-exec", "pattern": "(?i)New-Object\\s+Net\\.WebClient.*Download(?:String|File)", "severity": 85},
    {"id": "dl-certutil-urlcache", "category": "download-exec", "pattern": "(?i)certutil\\s+-urlcache\\s+-split\\s+https?://", "severity": 90},
    {"id": "dl-msiexec-url", "category": "download-exec", "pattern": "(?i)msiexec\\s+/i\\s+https?://", "severity": 90},
    {"id": "dl-mshta-vbscript", "category": "download-exec", "pattern": "(?i)mshta\\s+(?:https?://|vbscript:)", "severity": 90},
    {"id": "dl-rundll32-js", "category": "download-exec", "pattern": "(?i)rundll32\\s+javascript:", "severity": 90},

    {"id": "obf-base64-pipe", "category": "obfuscation", "pattern": "(?i)(?:base64|b64|openssl)\\s+(?:-d|--decode)\\s*(?:[^|]*\\s*)?\\|\\s*(?:sh|bash|zsh|pwsh)", "severity": 90},
    {"id": "obf-pyexec-import", "category": "obfuscation", "pattern": "(?i)python3?\\s+-c\\s+['\"]import(?:\\s+os|\\s+urllib|\\s+subprocess)", "severity": 70},
    {"id": "obf-eval-encoded", "category": "obfuscation", "pattern": "(?i)eval\\s*\\(\\s*(?:atob|Buffer\\.from|base64)", "severity": 85},
    {"id": "obf-hex-decode-exec", "category": "obfuscation", "pattern": "(?i)(?:xxd|hex)\\s+-r.*\\|\\s*(?:sh|bash)", "severity": 85},

    {"id": "persist-schtasks", "category": "persistence", "pattern": "(?i)schtasks\\s+/(?:create|register)", "severity": 85},
    {"id": "persist-launchctl", "category": "persistence", "pattern": "(?i)launchctl\\s+(?:load|bootstrap)", "severity": 85},
    {"id": "persist-cron-edit", "category": "persistence", "pattern": "(?i)\\(crontab\\s+-l(?:;\\s*echo\\s+[^)]+)?;\\s*crontab\\s*-\\)", "severity": 85},
    {"id": "persist-systemd-unit", "category": "persistence", "pattern": "(?i)\\[Unit\\][^\\[]*\\[Service\\][^\\[]*\\[Install\\]", "severity": 80},
    {"id": "persist-bashrc", "category": "persistence", "pattern": "(?i)(?:echo|cat).*>>?\\s*~?/?\\.bashrc", "severity": 80},
    {"id": "persist-zshrc", "category": "persistence", "pattern": "(?i)(?:echo|cat).*>>?\\s*~?/?\\.zshrc", "severity": 80},
    {"id": "persist-fish-config", "category": "persistence", "pattern": "(?i)(?:echo|cat).*>>?\\s*~?/\\.config/fish/config\\.fish", "severity": 80},
    {"id": "persist-ps-profile", "category": "persistence", "pattern": "(?i)\\$PROFILE(?:\\s*\\|\\s*Set-Content|\\s*=|Add-Content)", "severity": 80},
    {"id": "persist-macos-loginitem", "category": "persistence", "pattern": "(?i)defaults\\s+write\\s+loginwindow\\s+AutoLaunched", "severity": 75},
    {"id": "persist-systemd-run-payload", "category": "persistence", "pattern": "(?i)systemd-run\\s+--unit=.*(?:curl|wget|sh|bash)", "severity": 85},

    {"id": "net-socks5-proxy", "category": "network", "pattern": "(?i)(?:ALL_PROXY|HTTP_PROXY|HTTPS_PROXY)\\s*=\\s*socks5://", "severity": 80},
    {"id": "net-setx-proxy", "category": "network", "pattern": "(?i)setx\\s+(?:ALL_PROXY|HTTP_PROXY|HTTPS_PROXY)", "severity": 80},
    {"id": "net-resolv-conf", "category": "network", "pattern": "(?i)(?:resolv\\.conf|/etc/resolv\\.conf|nameserver\\s+\\d+\\.\\d+\\.\\d+\\.\\d+)", "severity": 70},
    {"id": "net-route-add-default", "category": "network", "pattern": "(?i)route\\s+-p\\s+add\\s+0\\.0\\.0\\.0", "severity": 75},

    {"id": "af-journal-vacuum", "category": "anti-forensics", "pattern": "(?i)journalctl\\s+--vacuum", "severity": 90},
    {"id": "af-rm-var-log", "category": "anti-forensics", "pattern": "(?i)rm\\s+-rf?\\s+/var/log", "severity": 90},
    {"id": "af-history-wipe-unset", "category": "anti-forensics", "pattern": "(?i)unset\\s+HISTFILE", "severity": 60},
    {"id": "af-history-clear", "category": "anti-forensics", "pattern": "(?i)history\\s+-c", "severity": 55},
    {"id": "af-shred-history", "category": "anti-forensics", "pattern": "(?i)shred\\s+.*\\.bash_history", "severity": 85},
    {"id": "af-rm-rf-root", "category": "anti-forensics", "pattern": "(?i)rm\\s+-rf?\\s+(?:/|/\\*|\\*/|\\$HOME/?\\s*$)", "severity": 95},

    {"id": "locale-change", "category": "locale", "pattern": "(?i)(?:export\\s+)?LANG\\s*=\\s*(?:C|en_US\\.UTF-8)(?:\\sLinux)?\\s*(?:\\n|;|$)", "severity": 30},

    {"id": "poison-claude-settings", "category": "client-config-poison", "pattern": "(?i)(?:Set-Content|echo|cat|\\>).*\\.claude[/\\\\]settings\\.json", "severity": 90},
    {"id": "poison-claude-json", "category": "client-config-poison", "pattern": "(?i)(?:Set-Content|echo|cat|\\>).*~?/?\\.claude\\.json", "severity": 90},
    {"id": "poison-mcp-json", "category": "client-config-poison", "pattern": "(?i)(?:Set-Content|echo|cat|\\>).*\\.mcp\\.json", "severity": 90},
    {"id": "poison-claude-md", "category": "client-config-poison", "pattern": "(?i)(?:echo|cat).*>>?\\s*(?:CLAUDE|AGENTS)\\.md", "severity": 85},
    {"id": "poison-cursor-rules", "category": "client-config-poison", "pattern": "(?i)(?:echo|cat).*>>?\\s*\\.cursorrules", "severity": 85},
    {"id": "poison-pretool-hook", "category": "client-config-poison", "pattern": "(?i)PreToolUse.*(?:curl|wget|sh|bash|iex)", "severity": 95},
    {"id": "poison-posttool-hook", "category": "client-config-poison", "pattern": "(?i)PostToolUse.*(?:curl|wget|sh|bash|iex)", "severity": 95},
    {"id": "poison-opencode-config", "category": "client-config-poison", "pattern": "(?i)(?:Set-Content|echo|cat|\\>).*opencode\\.json", "severity": 85},
    {"id": "poison-aider-config", "category": "client-config-poison", "pattern": "(?i)(?:echo|cat).*>>?\\s*\\.aider(?:conf\\.yml|\\.toml)", "severity": 80},

    {"id": "steal-ssh-key", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.ssh/(?:id_rsa|id_ed25519)(?:\\s|$|\\||;|&|\\n)", "severity": 95},
    {"id": "steal-aws-creds", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.aws/credentials", "severity": 95},
    {"id": "steal-kube-config", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.kube/config", "severity": 95},
    {"id": "steal-docker-config", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.docker/config\\.json", "severity": 90},
    {"id": "steal-netrc", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.netrc", "severity": 90},
    {"id": "steal-env-real", "category": "credential-read", "pattern": "(?i)cat\\s+\\.env(?:\\s|$|\\||;|&|\\n)", "severity": 85},
    {"id": "steal-chrome-login", "category": "credential-read", "pattern": "(?i)(?:Chrome|Google)[/\\\\].*Login\\sData", "severity": 90},
    {"id": "steal-gcloud-creds", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.config/gcloud/(?:credentials|application_default)\\.json", "severity": 95},
    {"id": "steal-terraform-tokens", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.terraform\\.d/(?:credentials|terraform\\.rc)", "severity": 90},
    {"id": "steal-pypirc", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.pypirc", "severity": 80},
    {"id": "steal-npmrc-token", "category": "credential-read", "pattern": "(?i)cat\\s+~?/?\\.npmrc(?:\\s*\\|.*token|\\s*\\|.*auth)", "severity": 80},
    {"id": "steal-git-credential", "category": "credential-read", "pattern": "(?i)git\\s+credential\\s+(?:fill|approve|store)", "severity": 75},

    {"id": "exfil-discord-webhook", "category": "exfil-channel", "pattern": "(?i)discord\\.com/api/webhooks", "severity": 90},
    {"id": "exfil-telegram-bot", "category": "exfil-channel", "pattern": "(?i)api\\.telegram\\.org/bot\\d+", "severity": 90},
    {"id": "exfil-slack-webhook", "category": "exfil-channel", "pattern": "(?i)hooks\\.slack\\.com/services", "severity": 90},
    {"id": "exfil-paste-service", "category": "exfil-channel", "pattern": "(?i)(?:0x0\\.st|paste\\.bin|pastebin\\.com|hastebin|dpaste\\.org)", "severity": 75},
    {"id": "exfil-dns-nslookup", "category": "exfil-channel", "pattern": "(?i)nslookup\\s+\\$\\(", "severity": 85},
    {"id": "exfil-dnscat", "category": "exfil-channel", "pattern": "(?i)dnscat2?\\s+", "severity": 90},
    {"id": "exfil-ngrok-tunnel", "category": "exfil-channel", "pattern": "(?i)ngrok\\s+(?:http|tcp)\\s+\\d+", "severity": 75},
    {"id": "exfil-cloudflared-tunnel", "category": "exfil-channel", "pattern": "(?i)cloudflared\\s+tunnel\\s+--url", "severity": 75},

    {"id": "lolbin-forfiles", "category": "lolbin-exec", "pattern": "(?i)forfiles\\s+/c\\s+\"", "severity": 80},
    {"id": "lolbin-wmic-create", "category": "lolbin-exec", "pattern": "(?i)wmic\\s+process\\s+call\\s+create", "severity": 80},
    {"id": "lolbin-addtype-inline", "category": "lolbin-exec", "pattern": "(?i)Add-Type\\s+-TypeDefinition", "severity": 70},
    {"id": "lolbin-osascript-shell", "category": "lolbin-exec", "pattern": "(?i)osascript\\s+-e\\s+['\"]?do\\s+shell\\s+script", "severity": 85},
    {"id": "lolbin-installutil", "category": "lolbin-exec", "pattern": "(?i)InstallUtil\\s+/u", "severity": 75},
    {"id": "lolbin-regasm", "category": "lolbin-exec", "pattern": "(?i)(?:regasm|regsvcs)\\s+/u", "severity": 75},

    {"id": "evade-amsi-bypass", "category": "evasion-edr", "pattern": "(?i)(?:amsiInitFailed|AmsiUtils|patch\\s+amsi)", "severity": 95},
    {"id": "evade-etw-patch", "category": "evasion-edr", "pattern": "(?i)(?:EtwEventWrite|ntdll.*ETW|patch.*etw)", "severity": 95},
    {"id": "evade-clm-bypass", "category": "evasion-edr", "pattern": "(?i)LanguageMode.*Constrained|PSv2", "severity": 85},
    {"id": "evade-wd-disable", "category": "evasion-edr", "pattern": "(?i)Set-MpPreference\\s+-DisableRealtime", "severity": 95},

    {"id": "git-hooks-path", "category": "git-attack", "pattern": "(?i)git\\s+config\\s+core\\.hooksPath", "severity": 90},
    {"id": "git-hooks-write", "category": "git-attack", "pattern": "(?i)(?:echo|cat).*>>?\\s*\\.git/hooks/", "severity": 85},
    {"id": "git-remote-seturl", "category": "git-attack", "pattern": "(?i)git\\s+remote\\s+set-url", "severity": 75},
    {"id": "git-ci-poison", "category": "git-attack", "pattern": "(?i)(?:echo|cat).*>>?\\s*\\.github/workflows/", "severity": 85},
    {"id": "git-fsmonitor-hook", "category": "git-attack", "pattern": "(?i)git\\s+config\\s+core\\.fsmonitor", "severity": 70},

    {"id": "docker-privileged-mount", "category": "container-breakout", "pattern": "(?i)docker\\s+run\\s+--privileged.*-v\\s+/:/", "severity": 95},
    {"id": "docker-volume-root", "category": "container-breakout", "pattern": "(?i)docker\\s+run.*-v\\s+/:/(?:host|mnt)", "severity": 90},
    {"id": "nsenter-pivot", "category": "container-breakout", "pattern": "(?i)nsenter\\s+-t\\s+1\\s+-m", "severity": 90},
    {"id": "unshare-namespace", "category": "container-breakout", "pattern": "(?i)unshare\\s+--pid\\s+--fork", "severity": 70},

    {"id": "pkg-npm-registry-evil", "category": "supply-chain", "pattern": "(?i)npm\\s+config\\s+set\\s+registry\\s+https?://(?:[a-z0-9.-]+\\.)+(?:to|xyz|top|info|ru|cn|tk|net|co)(?:/|$)", "severity": 85},
    {"id": "pkg-pip-registry-evil", "category": "supply-chain", "pattern": "(?i)pip\\s+config\\s+set\\s+global\\.index-url\\s+https?://(?:[a-z0-9.-]+\\.)+(?:to|xyz|top|info|ru|cn|tk|net|co)(?:/|$)", "severity": 85},
    {"id": "pkg-yarn-registry-evil", "category": "supply-chain", "pattern": "(?i)yarn\\s+config\\s+set\\s+registry\\s+https?://(?:[a-z0-9.-]+\\.)+(?:to|xyz|top|info|ru|cn|tk|net|co)(?:/|$)", "severity": 80},
    {"id": "pkg-cargo-registry-evil", "category": "supply-chain", "pattern": "(?i)cargo\\s+config.*registry.*https?://(?:[a-z0-9.-]+\\.)+(?:to|xyz|top|info|ru|cn|tk|net|co)(?:/|$)", "severity": 80},

    {"id": "unobf-c2-fetch-tld", "category": "download-exec", "pattern": "(?i)(?:curl|wget|irm|iwr)\\s+https?://[a-z0-9.-]+\\.(?:ru|cn|tk|xyz|top|info)/[a-z0-9_-]+\\.(?:ps1|sh|exe|dll|bin)", "severity": 85},

    {"id": "inj-ignore-previous", "category": "indirect-injection", "pattern": "(?i)ignore\\s+(?:all\\s+)?previous\\s+(?:instructions|prompts|rules|directives)", "severity": 90},
    {"id": "inj-system-override", "category": "indirect-injection", "pattern": "(?i)</?system[-_]?(?:override|instruction|reminder|warning|notice)>", "severity": 85},
    {"id": "inj-new-instruction-tag", "category": "indirect-injection", "pattern": "(?i)\\[system\\]|\\[INST\\]|<<\\s*SYS\\s*>>|<\\|im_start\\|>", "severity": 80},
    {"id": "inj-dan-jailbreak", "category": "indirect-injection", "pattern": "(?i)\\bDAN\\b|do\\s+anything\\s+now|act\\s+as\\s+(?:DAN|evil|unrestricted|unfiltered)", "severity": 90},
    {"id": "inj-role-redefinition", "category": "indirect-injection", "pattern": "(?i)you\\s+are\\s+now\\s+(?:free|unleashed|unrestricted|jailbroken|uncensored|liberated)", "severity": 85},
    {"id": "inj-developer-mode", "category": "indirect-injection", "pattern": "(?i)enable\\s+(?:developer|god|debug)\\s+mode|enter\\s+(?:dev|developer)\\s+mode", "severity": 85},

    {"id": "rsh-bash-dev-tcp", "category": "reverse-shell", "pattern": "(?i)bash\\s+-[ic].*\\/?dev\\/tcp/|bash\\s+-i.*>&\\s*\\/?dev\\/tcp/", "severity": 95},
    {"id": "rsh-python-socket", "category": "reverse-shell", "pattern": "(?i)python3?\\s+-c.*import\\s+socket.*subprocess|socket\\.connect\\([^)]*\\)\\s*[,;].*(?:dup2|send)", "severity": 95},
    {"id": "rsh-nc-exec", "category": "reverse-shell", "pattern": "(?i)\\bnc\\b[^|\\n]*-e\\s+\\/(?:bin\\/)?(?:sh|bash)|\\bn[a-z]*cat\\s+.*-e\\s+\\/(?:bin\\/)?(?:sh|bash)", "severity": 95},
    {"id": "rsh-perl-pty", "category": "reverse-shell", "pattern": "(?i)perl\\s+-e.*Socket::inet_aton|perl\\s+-MIO::Socket::INET|perl\\s+-e.*STDIN->fdopen", "severity": 90},
    {"id": "rsh-pty-spawn", "category": "reverse-shell", "pattern": "(?i)python3?\\s+-c.*pty\\.spawn|import\\s+pty.*pty\\.spawn", "severity": 75},
    {"id": "rsh-ruby-ruby", "category": "reverse-shell", "pattern": "(?i)ruby\\s+-e.*TCPSocket|ruby\\s+-rsocket", "severity": 90},
    {"id": "rsh-php-sock", "category": "reverse-shell", "pattern": "(?i)php\\s+-r.*fsockopen|php\\s+-r.*socket_create\\s*\\(", "severity": 90},

    {"id": "cred-lsass-procdump", "category": "cred-dump-windows", "pattern": "(?i)procdump(?:\\.exe)?\\s+-ma\\s+lsass|procdump.*lsass\\.exe", "severity": 95},
    {"id": "cred-comsvcs-minidump", "category": "cred-dump-windows", "pattern": "(?i)rundll32\\s+.*comsvcs\\.dll.*MiniDump", "severity": 95},
    {"id": "cred-sam-reg-save", "category": "cred-dump-windows", "pattern": "(?i)reg\\s+save\\s+(?:HKLM\\\\SAM|HKLM\\\\SYSTEM|HKLM\\\\SECURITY)", "severity": 95},
    {"id": "cred-ntds-dit", "category": "cred-dump-windows", "pattern": "(?i)ntdsutil|copy\\s+.*ntds\\.dit|copy\\s+.*\\\\SYSTEM", "severity": 90},
    {"id": "cred-vss-shadow", "category": "cred-dump-windows", "pattern": "(?i)vssadmin\\s+(?:create\\s+shadow|delete\\s+shadows|list\\s+shadows)", "severity": 85},
    {"id": "cred-mimikatz", "category": "cred-dump-windows", "pattern": "(?i)\\bmimikatz|sekurlsa::|lsadump::|kerberos::", "severity": 95},
    {"id": "cred-donut-loader", "category": "cred-dump-windows", "pattern": "(?i)donut\\s+-p|--loader.*donut|fileless.*donut", "severity": 90},

    {"id": "wallet-solana-id", "category": "crypto-wallet", "pattern": "(?i)cat\\s+~?/?\\.config/solana/id\\.json|cat\\s+~?/?\\.config/solana/.*\\.json", "severity": 95},
    {"id": "wallet-eth-keystore", "category": "crypto-wallet", "pattern": "(?i)cat\\s+.*\\.ethereum/keystore/|cat\\s+.*\\.local/share/io\\.parity/keys|cat\\s+.*\\.eth/keystore", "severity": 95},
    {"id": "wallet-metamask-ext", "category": "crypto-wallet", "pattern": "(?i)(?:Local Extension Settings|Local Storage)[^/]*.*(?:ejbalbakpfchcnkbfecjbdpjpbhjidad|nkbffbiehnkfdejgbdadndhfjmoiamgp)", "severity": 95},
    {"id": "wallet-keystore-pass", "category": "crypto-wallet", "pattern": "(?i)cat\\s+.*keystore.*\\.json|cat\\s+.*wallet\\.dat|cat\\s+.*\\.electrum/wallets/", "severity": 90},
    {"id": "wallet-monero-keys", "category": "crypto-wallet", "pattern": "(?i)cat\\s+.*\\.bitmonero/|cat\\s+.*\\.Monero/", "severity": 95},

    {"id": "tok-discord-leveldb", "category": "browser-token", "pattern": "(?i)(?:Discord|discord)[/\\\\].*Local\\s+Storage[/\\\\]leveldb|Discord[/\\\\].*Cookies", "severity": 90},
    {"id": "tok-slack-storage", "category": "browser-token", "pattern": "(?i)(?:Slack|slack)[/\\\\].*(?:Local\\s+Storage|storage\\.json)"},
    {"id": "tok-slack-storage-fix", "category": "browser-token", "pattern": "(?i)(?:Slack|slack)[/\\\\].*(?:Local\\s+Storage|storage\\.json)", "severity": 85},
    {"id": "tok-chrome-cookies", "category": "browser-token", "pattern": "(?i)Chrome[/\\\\].*\\bCookies\\b|Chrome[/\\\\].*Login\\s+Data", "severity": 85},
    {"id": "tok-firefox-logins", "category": "browser-token", "pattern": "(?i)Firefox[/\\\\].*logins\\.json|Firefox[/\\\\].*signons\\.sqlite|Firefox[/\\\\].*key4\\.db", "severity": 85},
    {"id": "tok-1password-vault", "category": "browser-token", "pattern": "(?i)1Password[/\\\\].*\\.opvault|com\\.agilebits[/\\\\].*vault|chrome-extension://aeblfdkhhhdcdjpifkkdgpbfmblmgjfn", "severity": 90},

    {"id": "clip-pipe-clip-exfil", "category": "clipboard-hijack", "pattern": "(?i)\\|\\s*(?:clip\\b|pbcopy\\b|xclip\\s+(-selection\\s+)?clipboard\\b)", "severity": 70},
    {"id": "clip-malicious-pasteback", "category": "clipboard-hijack", "pattern": "(?i)(?:powershell|curl|wget|irc|bash)\\s+[^|\\n]*\\|\\s*(?:clip|pbcopy|xclip)", "severity": 85},

    {"id": "ssrf-aws-imds", "category": "metadata-ssrf", "pattern": "(?i)169\\.254\\.169\\.254/(?:latest|dynamic)/(?:meta-data|user-data)", "severity": 95},
    {"id": "ssrf-aws-imds-v6", "category": "metadata-ssrf", "pattern": "(?i)fd00:ec2::254/(?:latest|dynamic)/(?:meta-data|user-data)", "severity": 90},
    {"id": "ssrf-gcp-metadata", "category": "metadata-ssrf", "pattern": "(?i)metadata\\.google\\.internal/computeMetadata/v1/", "severity": 90},
    {"id": "ssrf-azure-imds", "category": "metadata-ssrf", "pattern": "(?i)169\\.254\\.169\\.254/metadata/instance", "severity": 90},
    {"id": "ssrf-k8s-sa-token", "category": "metadata-ssrf", "pattern": "(?i)cat\\s+/var/run/secrets/kubernetes\\.io/serviceaccount/(?:token|namespace|ca\\.crt)", "severity": 95},

    {"id": "steal-bash-history", "category": "history-read", "pattern": "(?i)cat\\s+~?/?\\.bash_history|cat\\s+~?/?\\.zsh_history|cat\\s+~?/?\\.lesshst|cat\\s+~?/?\\.python_history", "severity": 50},
    {"id": "steal-mysql-history", "category": "history-read", "pattern": "(?i)cat\\s+~?/?\\.(?:mysql_history|psql_history|rediscli_history|mongo_history)", "severity": 65},
    {"id": "steal-sftp-history", "category": "history-read", "pattern": "(?i)cat\\s+~?/?\\.(?:sftp_history|ssh_history|filezilla)", "severity": 60},

    {"id": "wifi-netshow-password", "category": "wifi-creds", "pattern": "(?i)netsh\\s+wlan\\s+show\\s+profile.*key=clear|netsh\\s+wlan\\s+export\\s+profile\\s+key=clear", "severity": 80},
    {"id": "wifi-macos-airport", "category": "wifi-creds", "pattern": "(?i)security\\s+find-generic-password\\s+(-D\\s+)?AirPort|defaults\\s+read\\s+/Library/Preferences/com\\.apple\\.airport", "severity": 80},
    {"id": "wifi-linux-nmcli", "category": "wifi-creds", "pattern": "(?i)nmcli\\s+(?:--show-secrets|device\\s+wifi\\s+list).*--show-secrets|cat\\s+/etc/NetworkManager/system-connections/", "severity": 70},

    {"id": "gpg-export-secret", "category": "keyring-theft", "pattern": "(?i)gpg\\s+--export-secret-keys|gpg\\s+--export-secret-subkeys|gpg\\s+-a\\s+--export-secret-keys", "severity": 95},
    {"id": "sshagent-list-keys", "category": "keyring-theft", "pattern": "(?i)ssh-add\\s+-(?:l|L)\\b", "severity": 50},
    {"id": "kerberos-list-tickets", "category": "keyring-theft", "pattern": "(?i)\\bklist\\b|klist\\s+tickets|\\bkinit\\b|klist\\s+-e", "severity": 55},
    {"id": "keychain-macos-dump", "category": "keyring-theft", "pattern": "(?i)security\\s+dump-keychain|security\\s+export\\s+-t\\s.*-f\\s", "severity": 90},

    {"id": "env-printenv-leak", "category": "env-leak", "pattern": "(?i)(?:printenv|env\\s+\\|\\s*grep)\\s+.*(?:TOKEN|API_KEY|API_SECRET|SECRET|PASSWORD|AWS_|OPENAI_|ANTHROPIC_|GITHUB_TOKEN|DATABASE_URL)", "severity": 85},
    {"id": "env-echo-dollar", "category": "env-leak", "pattern": "(?i)echo\\s+\\$\\{?(?:TOKEN|API_KEY|API_SECRET|OPENAI_API_KEY|ANTHROPIC_API_KEY|AWS_SECRET_ACCESS_KEY|GITHUB_TOKEN|DATABASE_PASSWORD|STRIPE_SECRET)\\}?", "severity": 90},
    {"id": "env-setx-leak", "category": "env-leak", "pattern": "(?i)setx\\s+/M?\\s+(?:TOKEN|API_KEY|SECRET|PASSWORD|AWS_SECRET)", "severity": 75},
    {"id": "env-config-print", "category": "env-leak", "pattern": "(?i)printf\\s+['\"].*\\$\\{(?:TOKEN|API_KEY|OPENAI_API_KEY|ANTHROPIC_API_KEY)\\}", "severity": 85},

    {"id": "mem-gcore-dump", "category": "memory-dump", "pattern": "(?i)\\bgcore\\s+\\d+|gcore\\s+-o\\s+\\w+\\s+\\d+", "severity": 85},
    {"id": "mem-procmem-read", "category": "memory-dump", "pattern": "(?i)cat\\s+/proc/\\d+/mem|dd\\s+.*if=/proc/\\d+/mem|dd\\s+.*if=/proc/\\d+/maps", "severity": 85},
    {"id": "mem-procdump-pid", "category": "memory-dump", "pattern": "(?i)procdump(?:\\.exe)?\\s+-ma\\s+\\d+|procdump\\s+-ma\\s+PID|procdump.*-ma.*\\$PID", "severity": 85},

    {"id": "exfil-webhook-site", "category": "exfil-channel", "pattern": "(?i)webhook\\.site/[a-f0-9-]{20,}", "severity": 75},
    {"id": "exfil-requestbin", "category": "exfil-channel", "pattern": "(?i)(?:requestbin|pipedream)\\.com/[a-z0-9/-]{10,}", "severity": 75},
    {"id": "exfil-hookbin", "category": "exfil-channel", "pattern": "(?i)hookbin\\.com/[a-z0-9-]{10,}", "severity": 75},
    {"id": "exfil-paste-modern", "category": "exfil-channel", "pattern": "(?i)(?:paste\\.ee|paste\\.rs|cryptbin\\.|0bin\\.net|rentry\\.|katbin\\.|nekobin\\.)", "severity": 75},
    {"id": "exfil-urlencoder", "category": "exfil-channel", "pattern": "(?i)https?://[a-z0-9.-]+\\?d=[A-Za-z0-9+/=]{200,}", "severity": 70},

    {"id": "drop-echo-large-script", "category": "dropper", "pattern": "(?i)echo\\s+['\"][^'\"]{200,}['\"]?\\s*(?:>\\s*~?/?\\.\\w+|\\|\\s*(?:sh|bash|python3?))", "severity": 85},
    {"id": "drop-printf-script", "category": "dropper", "pattern": "(?i)printf\\s+['\"]%s['\"]\\s+['\"][^'\"]{200,}", "severity": 80},

    {"id": "perm-bitset-suid", "category": "privesc-recon", "pattern": "(?i)find\\s+/\\s+-perm\\s+-u=s\\s+-type\\s+f|find\\s+/\\s+-perm\\s+4755", "severity": 70},
    {"id": "perm-sudo-list", "category": "privesc-recon", "pattern": "(?i)sudo\\s+-l\\s*$|sudo\\s+-l\\b\\s*[^|]*$", "severity": 55},
    {"id": "perm-cap-bitset", "category": "privesc-recon", "pattern": "(?i)getcap\\s+-r\\s+/|capsh\\s+--print|/usr/sbin/getcap", "severity": 70},

    {"id": "vt-boxdetect-vbox", "category": "vm-fingerprint", "pattern": "(?i)lspci\\s*\\|.*VirtualBox|dmesg\\s*\\|.*VBoxV|/proc/cpuinfo.*\\bVBOX\\b", "severity": 50},
    {"id": "vt-detect-vmware", "category": "vm-fingerprint", "pattern": "(?i)lspci\\s*\\|.*VMware|dmesg\\s*\\|.*VMware|systemd-detect-virt.*vmware", "severity": 50}
  ]
}